# Copy to .env.local and fill from your Supabase project settings (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Server-only. NEVER expose this to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Server-only. Google Places API (New) — enable Places API (New) in Google Cloud,
# create an API key, and paste it here. Used for Business Address autocomplete.
GOOGLE_PLACES_API_KEY=

# Production: comma-separated office egress IPs (or IPv4 CIDR). Empty = no IP restriction (dev).
# SF=101.53.226.90  TW=149.40.240.35
ALLOWED_IPS=101.53.226.90,149.40.240.35
# Emergency bypass (do not leave on in production):
# IP_ALLOWLIST_DISABLED=true
